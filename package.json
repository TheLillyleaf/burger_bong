{
  "name": "my-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite",
    "dev:worker": "wrangler dev",
    "dev": "concurrently -n \"worker,frontend\" -c \"cyan,green\" \"wrangler dev\" \"vite\"",
    "build": "vite build",
    "deploy:worker": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply my-app-db --local",
    "db:migrate": "wrangler d1 migrations apply my-app-db",
    "lint": "eslint ."
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "hono": "^4.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1",
    "wrangler": "^4.78.0"
  }
}
